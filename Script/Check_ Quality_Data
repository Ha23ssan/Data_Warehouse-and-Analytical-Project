====================================================
             Check_ Null_Data 
====================================================

WITH null_data AS (
    SELECT 
        fs.Customer_Key,
        fs.Product_Key,
        fs.Order_Date
    FROM gold.Fact_Sales fs
    LEFT JOIN gold.Dim_Customers dc 
        ON fs.Customer_Key = dc.Customer_Key
    LEFT JOIN gold.Dim_Products dp
        ON fs.Product_Key = dp.Product_Key
    WHERE dp.Product_Key IS NULL 
       OR dc.Customer_Key IS NULL  
       OR fs.Order_Date IS NULL
)

INSERT INTO dq_log(check_name, status, failed_rows, run_time)

SELECT 
    'null_data',
    CASE 
        WHEN COUNT(*) = 0 THEN 'PASS'
        ELSE 'FAIL'
    END,
    count(*),
    GETDATE()
FROM null_data


====================================================
             Check_ Duplicate_Data 
====================================================

INSERT INTO dq_log (check_name, status, failed_rows, run_time)
SELECT
    'duplicate_customers',
    CASE 
    WHEN COUNT(*) = 0 THEN 'PASS'
    ELSE 'FAIL'
    END,
    COUNT(*),
    GETDATE()
FROM (
    SELECT Customer_ID
    FROM gold.Dim_Customers
    GROUP BY Customer_ID
    HAVING COUNT(*) > 1
) d;


