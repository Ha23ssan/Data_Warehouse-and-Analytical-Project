====================================================
             Check_ business_rules 
====================================================

WITH bad_rows AS (
    SELECT *
    FROM gold.Fact_Sales
    WHERE Revenue <= 0
    OR Quantity < 0
    OR Price <= 0
    OR Order_Date > GETDATE()
)
INSERT INTO dq_log (check_name, status, failed_rows, run_time)
SELECT
    'business_rules',
    CASE 
        WHEN COUNT(*) = 0 THEN 'PASS'
        ELSE 'FAIL'
    END,
    COUNT(*),
    GETDATE()
FROM bad_rows;

