
from airflow import DAG
from airflow.providers.common.sql.operators.sql import SQLExecuteQueryOperator
from datetime import datetime
from datetime import timedelta

default_args = {
    "retries": 3,
    "retry_delay": timedelta(minutes=10)
}

with DAG(
    dag_id="dw_full_pipeline",
    start_date=datetime(2026, 5, 18),
    schedule='0 6 * * *',
    catchup=False 
    
) as dag:

    bronze = SQLExecuteQueryOperator(
        task_id="Full_Load_bronze",
        conn_id="sql_server_dw",
        sql="EXEC bronze.Full_Load;"
    )

    silver = SQLExecuteQueryOperator(
        task_id="Full_Load_silver",
        conn_id="sql_server_dw",
        sql="EXEC silver.Full_Load;"
    )

    gold = SQLExecuteQueryOperator(
        task_id="Incremental_Load_gold",
        conn_id="sql_server_dw",
        sql="EXEC gold.Incremental_Load;"
    )

   
    
    

    bronze >> silver >>  gold 
